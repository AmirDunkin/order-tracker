# Railway environment template for OrderTrack
# Copy these into Railway → Service → Variables
# Link a MySQL plugin so MYSQL* variables are available

APP_ENV=production
APP_URL=https://your-railway-url.up.railway.app
APP_TIMEZONE=Asia/Kuala_Lumpur

DB_HOST=$MYSQLHOST
DB_DATABASE=$MYSQLDATABASE
DB_USERNAME=$MYSQLUSER
DB_PASSWORD=$MYSQLPASSWORD
DB_PORT=$MYSQLPORT
