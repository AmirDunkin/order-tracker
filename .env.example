# OrderTrack environment variables
# Copy to your server configuration or set via cPanel → PHP Variables / .htaccess SetEnv

# Local XAMPP (Apache port 8080, IIS uses port 80)
APP_URL=http://localhost:8080/order-tracker/public
APP_TIMEZONE=Asia/Kuala_Lumpur

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yourcpanel_order_tracker
DB_USERNAME=yourcpanel_dbuser
DB_PASSWORD=your_secure_password

# Optional — enables OpenAI-powered shopping tips (falls back to rules if empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email notifications (status updates). On local, emails are logged to storage/logs/mail.log
MAIL_ENABLED=true
MAIL_LOG_ONLY=true
MAIL_FROM_ADDRESS=noreply@ordertrack.local
MAIL_FROM_NAME=OrderTrack
